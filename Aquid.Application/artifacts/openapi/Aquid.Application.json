            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "dateTimeFirst": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "dateTimeLast": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "parameters": {
