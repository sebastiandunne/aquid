{
  "name": "aquid.web",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "test:unit": "vitest run",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "generate:openapi-types": "pnpm exec openapi-typescript ../Aquid.Application/artifacts/openapi/Aquid.Application.json -o ./src/types/aquid-schema.d.ts && pnpm exec eslint --fix ./src/types/aquid-schema.d.ts",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-mono": "^5.2.8",
    "@mdi/font": "7.4.47",
    "@sentry/vue": "^10.56.0",
    "@tanstack/vue-query": "^5.101.0",
    "@vueuse/router": "^14.3.0",
    "dayjs": "^1.11.21",
    "lil-gui": "^0.21.0",
    "lodash": "^4.18.1",
    "mapbox-gl": "^3.24.0",
    "openapi-fetch": "^0.17.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@intellectronica/ruler": "^0.3.37",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.4",
    "eslint-config-vuetify": "^4.3.4",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.13.0",
    "sass-embedded": "^1.98.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "unplugin-fonts": {
      "vite": "^8.0.0"
    }
  }
}
